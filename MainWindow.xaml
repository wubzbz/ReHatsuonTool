<Window x:Class="ReHatsuonTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ReHatsuonTool.ViewModels"
        xmlns:conv="clr-namespace:ReHatsuonTool.Views"
        xmlns:loc="clr-namespace:ReHatsuonTool.Localization"
        mc:Ignorable="d"
        Title="Re-Hatsuon Tool - 添加普通话语音物件"
        Height="610" Width="880"
        MinHeight="610" MinWidth="780"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:PageTypeToIndexConverter x:Key="PageTypeConverter" />
        <conv:InverseBoolConverter x:Key="InverseBoolConverter" />

        <!-- Raised white button with border and shadow -->
        <Style x:Key="WhiteButton" BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="#4AFFFFFF"
                                BorderBrush="LightGray"
                                BorderThickness="3,0,0,0"
                                Padding="16,16"
                                Cursor="Hand">
                            <ContentPresenter x:Name="content"
                                VerticalAlignment="Center"
                                TextBlock.Foreground="{DynamicResource MaterialDesignBody}"
                                TextBlock.FontFamily="Microsoft Sans Serif"
                                TextBlock.FontSize="16"
                                TextBlock.FontWeight="Bold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#145C6B" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}" />
                                <Setter TargetName="content" Property="TextBlock.Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="content" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavSaveButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                BorderBrush="LightGray"
                                BorderThickness="3,0,0,0"
                                Padding="16,16"
                                Cursor="Hand">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#4AFFFFFF" Offset="0.8"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter x:Name="content"
                                VerticalAlignment="Center"
                                TextBlock.Foreground="{DynamicResource MaterialDesignBody}"
                                TextBlock.FontFamily="Microsoft Sans Serif"
                                TextBlock.FontSize="16"
                                TextBlock.FontWeight="Bold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#145C6B" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}" />
                                <Setter TargetName="content" Property="TextBlock.Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="content" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- NavSide -->
        <Border Grid.Column="0"
                Background="#FFFCE6B5"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="0,0,1,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Image Grid.Row="1" Grid.RowSpan="3"
                       Source="/Images/nav-bg.png"
                       Stretch="None"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Stretch"
                       Width="198"
                       Panel.ZIndex="-1" />

                <Border Grid.Row="0" Padding="16,28">
                    <Border.Background>
                        <ImageBrush ImageSource="/Images/Title-bar.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="Re-Hatsuon Tool"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   Foreground="White" />
                        <TextBlock Text="{Binding VersionText}"
                                   FontSize="12"
                                   TextAlignment="Right"
                                   Foreground="#BAFFFFFF"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <RadioButton x:Name="NavSetup"
                                 Style="{StaticResource NavButtonStyle}"
                                 Content="{x:Static loc:Texts.NavSetup}"
                                 GroupName="Nav"
                                 Checked="NavSetup_Checked" />

                    <RadioButton x:Name="NavAdd"
                                 Style="{StaticResource NavButtonStyle}"
                                 Content="{x:Static loc:Texts.NavAdd}"
                                 GroupName="Nav"
                                 IsEnabled="{Binding CanNavigateToAddLines}"
                                 Checked="NavAdd_Checked" />

                    <RadioButton x:Name="NavSave"
                                 Style="{StaticResource NavSaveButtonStyle}"
                                 Content="{x:Static loc:Texts.NavSave}"
                                 GroupName="Nav"
                                 IsEnabled="{Binding CanNavigateToSave}"
                                 Checked="NavSave_Checked" />
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,0,0,12" HorizontalAlignment="Center">
                    <!-- Powered by Yukkuri-Mandarin badge -->
                    <Image Source="/Images/badge.png"
                           Width="170"
                           Margin="0,0,0,8"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <!-- License -->
                    <TextBlock Text="{Binding LicenseText}"
                        FontSize="10"
                        FontWeight="Bold"
                        Foreground="{DynamicResource PrimaryHueDarkBrush}"
                        HorizontalAlignment="Center"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1">
            <!-- Setup Page -->
            <Grid x:Name="SetupPage"
                  Visibility="Visible"
                  DataContext="{Binding SetupViewModel}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource PrimaryHueLightBrush}"
                        Padding="24,16">
                    <TextBlock Text="{x:Static loc:Texts.SetupPageTitle}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryHueDarkBrush}" />
                </Border>

                <!-- Setup Complete Indicator (top) -->
                <Border Grid.Row="1"
                        Padding="14,10" CornerRadius="0"
                        Background="{DynamicResource PrimaryHueMidBrush}"
                        Visibility="{Binding IsSetupComplete, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{x:Static loc:Texts.SetupCompleteBanner}"
                               Foreground="White"
                               FontWeight="SemiBold" FontSize="13"
                               HorizontalAlignment="Center" />
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">

                        <!-- YMM4 Card -->
                        <materialDesign:Card Margin="0,0,0,16" Padding="20">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:Texts.Ymm4StepTitle}"
                                           FontSize="17" FontWeight="SemiBold"
                                           Margin="0,0,0,12" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Ymm4Directory, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="{x:Static loc:Texts.Ymm4StepHint}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0" />
                                    <Button Grid.Column="1"
                                            Command="{Binding BrowseYmm4Command}"
                                            Style="{StaticResource WhiteButton}"
                                            Background="White"
                                            Foreground="#FF00675B"
                                            Content="..."
                                            Padding="12,6" />
                                </Grid>

                                <!-- Result -->
                                <Border Margin="0,12,0,0"
                                        Padding="10"
                                        Background="{DynamicResource MaterialDesignCardBackground}"
                                        CornerRadius="4">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="EXE: " FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Ymm4Status}"
                                                       Foreground="{DynamicResource MaterialDesignBody}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding VersionInfo}"
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                   FontWeight="SemiBold"
                                                   Visibility="{Binding IsYmm4Valid, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock Text="{Binding CharactersSummary}"
                                                   Foreground="{DynamicResource MaterialDesignBody}"
                                                   FontSize="12"
                                                   Visibility="{Binding IsYmm4Valid, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <!-- Warning -->
                                <Border Margin="0,8,0,0"
                                        Padding="10,6" CornerRadius="4"
                                        Background="#FFF3F0"
                                        Visibility="{Binding IsYmm4Valid, Converter={StaticResource InverseBoolConverter}}">
                                    <TextBlock Text="{x:Static loc:Texts.Ymm4StepWarning}"
                                               Foreground="#CC3300" FontSize="12" />
                                </Border>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Ymmp Card -->
                        <materialDesign:Card Padding="20">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:Texts.YmmpStepTitle}"
                                           FontSize="17" FontWeight="SemiBold"
                                           Margin="0,0,0,12" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding YmmpFilePath, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="{x:Static loc:Texts.YmmpStepHint}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0" />
                                    <Button Grid.Column="1"
                                            Command="{Binding BrowseYmmpCommand}"
                                            Style="{StaticResource WhiteButton}"
                                            Content="..."
                                            Padding="12,6" />
                                </Grid>

                                <Border Margin="0,12,0,0"
                                        Padding="10"
                                        Background="{DynamicResource MaterialDesignCardBackground}"
                                        CornerRadius="4">
                                    <TextBlock Text="{Binding YmmpStatus}"
                                               Foreground="{DynamicResource MaterialDesignBody}"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                </Border>

                                <Border Margin="0,8,0,0"
                                        Padding="10,6" CornerRadius="4"
                                        Background="#FFF3F0"
                                        Visibility="{Binding IsYmmpValid, Converter={StaticResource InverseBoolConverter}}">
                                    <TextBlock Text="{x:Static loc:Texts.YmmpStepWarning}"
                                               Foreground="#CC3300" FontSize="12" />
                                </Border>
                            </StackPanel>
                        </materialDesign:Card>



                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- AddLines Page -->
            <Grid x:Name="AddLinesPage" Visibility="Collapsed"
                  DataContext="{Binding AddLinesViewModel}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource PrimaryHueLightBrush}"
                        Padding="24,16">
                    <TextBlock Text="{x:Static loc:Texts.AddLinesPageTitle}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryHueDarkBrush}" />
                </Border>

                <Grid Grid.Row="1" Margin="24,12,24,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{x:Static loc:Texts.AddLinesTimelineLabel}" FontSize="14"
                               VerticalAlignment="Center" FontWeight="SemiBold" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding TimelineNames}"
                              SelectedItem="{Binding SelectedTimelineName}"
                              MinWidth="180"
                              FontSize="14"
                              Margin="4,0,12,0"
                              materialDesign:HintAssist.Hint="{x:Static loc:Texts.AddLinesTimelineHint}" />

                    <Button Grid.Column="3"
                            Command="{Binding ImportCsvCommand}"
                            Style="{StaticResource WhiteButton}"
                            Content="{x:Static loc:Texts.AddLinesImportCsvButton}"
                            Padding="12,6" />
                </Grid>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Lines}"
                                  Margin="24,0,24,16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Color swatch -->
                                    <Rectangle Grid.Column="0"
                                               Width="10" Height="32"
                                               RadiusX="4" RadiusY="4"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               Fill="{Binding ColorBrush}" />

                                    <!-- Character combo -->
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding DataContext.AllCharacters, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              SelectedItem="{Binding Character, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="Name"
                                              materialDesign:HintAssist.Hint="{x:Static loc:Texts.AddLinesCharacterHint}"
                                              Margin="0,0,8,0" />

                                    <!-- Serif textbox with colored glow -->
                                    <Border Grid.Column="2"
                                            CornerRadius="4"
                                            Padding="1"
                                            Background="{Binding GlowBrush}">
                                        <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderThickness="0"
                                                 Padding="8,6"
                                                 Background="White"
                                                 FontSize="14"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 MaxHeight="84"
                                                 VerticalScrollBarVisibility="Auto"
                                                 materialDesign:HintAssist.Hint="{x:Static loc:Texts.AddLinesSerifHint}" />
                                    </Border>

                                    <!-- Delete button -->
                                    <Button Grid.Column="3"
                                            Command="{Binding DataContext.DeleteLineCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Width="30" Height="30"
                                            Margin="8,0,0,0"
                                            Padding="0"
                                            Background="White"
                                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            ToolTip="{x:Static loc:Texts.AddLinesDeleteTooltip}"
                                            Visibility="{Binding CanDelete, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="❌"
                                                   FontSize="14" FontWeight="Bold"
                                                   Foreground="#CC3333"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Save Page -->
            <Grid x:Name="SavePage" Visibility="Collapsed"
                  DataContext="{Binding SaveViewModel}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource PrimaryHueLightBrush}"
                        Padding="24,16">
                    <TextBlock Text="{x:Static loc:Texts.SavePageTitle}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryHueDarkBrush}" />
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">

                        <!-- Export CSV -->
                        <materialDesign:Card Margin="0,0,0,16" Padding="20">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:Texts.SaveExportSectionTitle}"
                                           FontSize="16" FontWeight="SemiBold"
                                           Margin="0,0,0,12" />

                                 <Button Command="{Binding ExportCsvCommand}"
                                         Style="{StaticResource WhiteButton}"
                                         Content="{x:Static loc:Texts.SaveExportButton}"
                                         IsEnabled="{Binding CanSave}"
                                         Padding="12,6"
                                        HorizontalAlignment="Left" />

                                <TextBlock Margin="0,12,0,0"
                                           FontSize="13"
                                           Foreground="{DynamicResource MaterialDesignBody}"
                                           TextWrapping="Wrap">
                                    <Run Text="{x:Static loc:Texts.SaveExportDesc1}"/>
                                    <Run Text="{Binding ValidLineCount, Mode=OneWay}" FontWeight="SemiBold"/>
                                    <Run Text="{x:Static loc:Texts.SaveExportDesc2}" />
                                </TextBlock>

                                <TextBlock Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource PrimaryHueMidBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasExportPath, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Run Text="{x:Static loc:Texts.SaveExportedTo}"/>
                                    <Run Text="{Binding ExportSavedPath, Mode=OneWay}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Append to Ymmp -->
                        <materialDesign:Card Padding="20">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:Texts.SaveYmmpAppendSectionTitle}"
                                           FontSize="16" FontWeight="SemiBold"
                                           Margin="0,0,0,12" />

                                <Border Padding="12"
                                        Background="{DynamicResource MaterialDesignCardBackground}"
                                        CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static loc:Texts.SaveYmmpPathLabel}" FontWeight="SemiBold" FontSize="12" Margin="0,2" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding YmmpPath}" FontSize="12" Margin="0,2" TextTrimming="CharacterEllipsis" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static loc:Texts.SaveYmmpTimelineLabel}" FontWeight="SemiBold" FontSize="12" Margin="0,2" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding YmmpTimeline}" FontSize="12" Margin="0,2" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static loc:Texts.SaveYmmpItemCountLabel}" FontWeight="SemiBold" FontSize="12" Margin="0,2" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" FontSize="12" Margin="0,2">
                                            <Run Text="{Binding YmmpExistingCount, Mode=OneWay}" />
                                            <Run Text="{x:Static loc:Texts.SaveYmmpItemsCountUnit}" />
                                        </TextBlock>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static loc:Texts.SaveYmmpStartTimeLabel}" FontWeight="SemiBold" FontSize="12" Margin="0,2" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding YmmpStartTime}" FontSize="12" Margin="0,2" />
                                    </Grid>
                                </Border>

                                 <Button Margin="0,12,0,0"
                                         Command="{Binding AppendToYmmpCommand}"
                                         Style="{StaticResource WhiteButton}"
                                         Content="{x:Static loc:Texts.SaveAppendButton}"
                                         IsEnabled="{Binding CanSave}"
                                         Padding="12,6"
                                        HorizontalAlignment="Left" />

                                <CheckBox Margin="0,8,0,0"
                                          IsChecked="{Binding KeepLinesAfterAppend}"
                                          Content="{x:Static loc:Texts.SaveKeepLines}"
                                          FontSize="12"
                                          Foreground="{DynamicResource MaterialDesignBody}" />

                                <TextBlock Margin="0,8,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource PrimaryHueDarkBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding AppendStatus}" />
                            </StackPanel>
                        </materialDesign:Card>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
